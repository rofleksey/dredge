{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate:openapi": "npx openapi-typescript-codegen --input ../api/openapi.yaml --output src/api/generated --client axios --useOptions",
    "generate:api": "npm run generate:openapi"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "axios": "^1.15.0",
    "echarts": "^5.6.0",
    "pinia": "^3.0.4",
    "reconnecting-websocket": "^4.4.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "openapi-typescript-codegen": "^0.30.0",
    "sass": "^1.99.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6"
  }
}
